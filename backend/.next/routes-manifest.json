{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/conversations/[conversationId]",
      "regex": "^/api/conversations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPconversationId": "nxtPconversationId"
      },
      "namedRegex": "^/api/conversations/(?<nxtPconversationId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/conversations/[conversationId]/messages",
      "regex": "^/api/conversations/([^/]+?)/messages(?:/)?$",
      "routeKeys": {
        "nxtPconversationId": "nxtPconversationId"
      },
      "namedRegex": "^/api/conversations/(?<nxtPconversationId>[^/]+?)/messages(?:/)?$"
    },
    {
      "page": "/api/creators/[creatorId]/follow",
      "regex": "^/api/creators/([^/]+?)/follow(?:/)?$",
      "routeKeys": {
        "nxtPcreatorId": "nxtPcreatorId"
      },
      "namedRegex": "^/api/creators/(?<nxtPcreatorId>[^/]+?)/follow(?:/)?$"
    },
    {
      "page": "/api/creators/[creatorId]/subscribe",
      "regex": "^/api/creators/([^/]+?)/subscribe(?:/)?$",
      "routeKeys": {
        "nxtPcreatorId": "nxtPcreatorId"
      },
      "namedRegex": "^/api/creators/(?<nxtPcreatorId>[^/]+?)/subscribe(?:/)?$"
    },
    {
      "page": "/api/posts/[postId]/bookmark",
      "regex": "^/api/posts/([^/]+?)/bookmark(?:/)?$",
      "routeKeys": {
        "nxtPpostId": "nxtPpostId"
      },
      "namedRegex": "^/api/posts/(?<nxtPpostId>[^/]+?)/bookmark(?:/)?$"
    },
    {
      "page": "/api/posts/[postId]/like",
      "regex": "^/api/posts/([^/]+?)/like(?:/)?$",
      "routeKeys": {
        "nxtPpostId": "nxtPpostId"
      },
      "namedRegex": "^/api/posts/(?<nxtPpostId>[^/]+?)/like(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/account",
      "regex": "^/api/account(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/account(?:/)?$"
    },
    {
      "page": "/api/conversations",
      "regex": "^/api/conversations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/conversations(?:/)?$"
    },
    {
      "page": "/api/creator-applications",
      "regex": "^/api/creator\\-applications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/creator\\-applications(?:/)?$"
    },
    {
      "page": "/api/creator-applications/verification",
      "regex": "^/api/creator\\-applications/verification(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/creator\\-applications/verification(?:/)?$"
    },
    {
      "page": "/api/creator-applications/verification/callback",
      "regex": "^/api/creator\\-applications/verification/callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/creator\\-applications/verification/callback(?:/)?$"
    },
    {
      "page": "/api/health",
      "regex": "^/api/health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/health(?:/)?$"
    },
    {
      "page": "/api/payments/create-checkout-session",
      "regex": "^/api/payments/create\\-checkout\\-session(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/payments/create\\-checkout\\-session(?:/)?$"
    },
    {
      "page": "/api/payments/webhook",
      "regex": "^/api/payments/webhook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/payments/webhook(?:/)?$"
    },
    {
      "page": "/api/posts",
      "regex": "^/api/posts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/posts(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}